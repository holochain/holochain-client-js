{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "strict": true,
    "typeRoots": ["./node_modules/@types", "./typings"]
  },
  "include": ["./src/**/*", "./typings"]
}
